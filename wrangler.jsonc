{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "optiyou",
  "main": "src/index.ts",
  "account_id": "75c2ecd9fee15d06f93013c411f31aaa",
  "compatibility_date": "2026-05-25",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "minify": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "persist": true
    },
    "traces": {
      "enabled": true,
      "persist": true
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "optiyou-core",
      "database_id": "26a81560-57d1-4ccb-85bd-db36520159e7",
      "migrations_dir": "migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "PRODUCT_CACHE",
      "id": "52fb781a420d49289ab9477ee3146835"
    },
    {
      "binding": "APP_CONFIG",
      "id": "2352f654efad43d1a11f8722cebacdc1"
    },
    {
      "binding": "METHODOLOGY_CACHE",
      "id": "83ead3db2c1c41fdb9cd2f1c272e47b8"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "INGESTION_QUEUE",
        "queue": "optiyou-ingestion"
      },
      {
        "binding": "NOTIFICATION_QUEUE",
        "queue": "optiyou-notifications"
      }
    ],
    "consumers": [
      {
        "queue": "optiyou-ingestion",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3,
        "dead_letter_queue": "optiyou-ingestion-dlq"
      }
    ]
  },
  "ai": {
    "binding": "AI"
  },
  "vectorize": [
    {
      "binding": "PRODUCT_EVIDENCE_INDEX",
      "index_name": "optiyou-product-evidence"
    }
  ],
  "routes": [
    {
      "pattern": "optiyou.co/*",
      "zone_name": "optiyou.co"
    },
    {
      "pattern": "www.optiyou.co/*",
      "zone_name": "optiyou.co"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "CANONICAL_HOST": "optiyou.co",
    "UPLOAD_TOKEN_TTL_SECONDS": "900",
    "METHODOLOGY_VERSION": "food-us-ca-v1",
    "AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1"
  }
}
